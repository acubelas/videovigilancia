# Ejemplo de variables de entorno para videovigilancia

# Cámara
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FPS=30

# Twilio (SMS)
# Para habilitar Twilio, establece TWILIO_ENABLED=True y rellena las credenciales
TWILIO_ENABLED=False
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15557654321

# Telegram (opcional)
TELEGRAM_ENABLED=True
TELEGRAM_BOT_TOKEN=8493512920:AAEX79oJZQIb0hUvYqSqdVfjMa7_v_7RSoA
TELEGRAM_CHAT_ID=720712344

# Grabación
RECORDING_ENABLED=False
RECORDING_DIR=recordings
# Variables de entorno para la aplicación de videovigilancia
# Reemplaza los valores con tus credenciales reales

# ============================================
# CONFIGURACIÓN DE CÁMARA
# ============================================
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FPS=30

# ============================================
# CONFIGURACIÓN DE DETECCIÓN DE MOVIMIENTO
# ============================================
MOTION_THRESHOLD=5.0
BLUR_KERNEL_SIZE=21
MIN_CONTOUR_AREA=500.0
CONFIDENCE_THRESHOLD=2.0
ALERT_COOLDOWN=30

# ============================================
# CONFIGURACIÓN DE TELEGRAM
# ============================================
TELEGRAM_ENABLED=True
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ============================================
# CONFIGURACIÓN DE TWILIO (SMS)
# ============================================
TWILIO_ENABLED=False
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOG_LEVEL=INFO
MAX_LOG_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# CONFIGURACIÓN DE GRABACIÓN
# ============================================
RECORDING_ENABLED=False
RECORDING_DIR=./recordings
RECORDING_FPS=20
RECORDING_CODEC=mp4v
